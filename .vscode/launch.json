{
  // https://github.com/microsoft/vscode-js-debug#readme
  "version": "0.2.0",
  "configurations": [
    {
      "type": "firefox",
      "request": "launch",
      "reAttach": true,
      "name": "Launch firefox localhost",
      "url": "http://localhost:3000/monaka/",
      "webRoot": "${workspaceFolder}/docs"
    },
    {
      "name": "Launch Edge",
      "request": "launch",
      "type": "pwa-msedge",
      "url": "http://localhost:3000/monaka/",
      "webRoot": "${workspaceFolder}/docs"
    },
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:3000/monaka/",
      "webRoot": "${workspaceFolder}/docs"
    }
  ]
}