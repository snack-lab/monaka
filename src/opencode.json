{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "disabled_providers": [
    "opencode"
  ],
  "default_agent": "plan",
  "watcher": {
    "ignore": [
      "node_modules/**"
    ]
  },
  "model": "dmr/gemma4:E4B",
  "provider": {
    "dmr": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Model Runner",
      "options": {
        "baseURL": "http://model-runner.docker.internal/v1/"
      },
      "models": {
        "gemma4:E4B": {
          "name": "gemma4:E4B"
        }
      }
    }
  },
  "instructions": [],
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "ssh *": "deny",
      "scp *": "deny",
      "sftp *": "deny",
      "telnet *": "deny",
      "ftp *": "deny",
      "npm *": "ask"
    },
    "read": {
      "*": "allow",
      "*.env.example": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "webfetch": "ask",
    "external_directory": "deny"
  }
}
